# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://user:password@localhost:5432/project"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://user:password@localhost:5432/project"

# Server
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# API Keys (placeholder)
TRADING_VIEW_WEBHOOK_SECRET="your-secret-key"

# Risk Management
MAX_DAILY_LOSS_PERCENT=5
MAX_OPEN_TRADES=10
POSITION_RISK_PERCENT=2

# Logging
LOG_LEVEL="info"

# Authentication - JWT
JWT_SECRET="your-jwt-secret-key-min-32-chars-recommended"

# Authentication - Cookies
COOKIE_SECRET="your-cookie-secret-key-min-32-chars-recommended"
COOKIE_SECURE="false"
COOKIE_SAME_SITE="lax"
COOKIE_MAX_AGE="28800000"

DEMO_PASSWORD="DEMO_PASSWORD"